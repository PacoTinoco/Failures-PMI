// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COORDINATOR
  OPERATOR
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          Role     @default(OPERATOR)
  createdAt     DateTime @default(now())
  coordinator   Coordinator?
  operator      Operator?
  uploadLogs    UploadLog[]
}

model Machine {
  id            String        @id @default(cuid())
  name          String        @unique
  code          String        @unique
  createdAt     DateTime      @default(now())
  coordinators  Coordinator[]
  operators     Operator[]
}

model Coordinator {
  id        String      @id @default(cuid())
  name      String
  machineId String
  userId    String?     @unique
  machine   Machine     @relation(fields: [machineId], references: [id])
  user      User?       @relation(fields: [userId], references: [id])
  operators Operator[]
}

model Operator {
  id            String          @id @default(cuid())
  name          String
  coordinatorId String
  machineId     String
  userId        String?         @unique
  coordinator   Coordinator     @relation(fields: [coordinatorId], references: [id])
  machine       Machine         @relation(fields: [machineId], references: [id])
  user          User?           @relation(fields: [userId], references: [id])
  weeklyRecords WeeklyRecord[]
}

model KpiDefinition {
  id               String  @id @default(cuid())
  code             String  @unique
  name             String
  category         String
  categoryName     String
  unit             String
  defaultObjective Float?
  sortOrder        Int
}

model WeeklyRecord {
  id         String     @id @default(cuid())
  operatorId String
  weekStart  DateTime
  year       Int
  weekNumber Int
  createdAt  DateTime   @default(now())
  createdBy  String?
  operator   Operator   @relation(fields: [operatorId], references: [id])
  kpiValues  KpiValue[]

  @@unique([operatorId, weekStart])
}

model KpiValue {
  id             String       @id @default(cuid())
  weeklyRecordId String
  kpiCode        String
  value          Float
  objective      Float?
  weeklyRecord   WeeklyRecord @relation(fields: [weeklyRecordId], references: [id], onDelete: Cascade)

  @@unique([weeklyRecordId, kpiCode])
}

model UploadLog {
  id            String   @id @default(cuid())
  userId        String
  filename      String
  machineId     String?
  rowsProcessed Int
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}
