# ============================================================
# CONFIGURACIÓN — Copia este archivo como .env y llena los valores
# ============================================================

# Supabase (Settings → API en tu proyecto)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=eyJ...tu-anon-key
SUPABASE_SERVICE_KEY=eyJ...tu-service-role-key

# Dominio corporativo permitido para registro
ALLOWED_EMAIL_DOMAIN=pmintl.net

# URL del frontend (para CORS y redirects de Magic Link)
FRONTEND_URL=https://tuapp.onrender.com

# Entorno
ENVIRONMENT=development
